###  https://prov-cred.org/ns/wn18rr
provcred:wn18rr rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:altLabel "WordNet 18RR"@en ;
                skos:definition "A KGE completion benchmark derived from WordNet with inverse relations removed to prevent test leakage."@en ;
