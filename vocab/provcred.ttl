###  https://prov-cred.org/ns/semeval-2010-task8
provcred:semeval-2010-task8 rdf:type owl:NamedIndividual ,
                                     skos:Concept ;
                            skos:definition "Shared task dataset for multi-way classification of semantic relations between pairs of nominals in English. Nine directed relation types plus Other."@en ;
                            skos:exactMatch <https://paperswithcode.com/dataset/semeval-2010-task-8> ;
                            skos:inScheme provcred:DatasetScheme ;
                            skos:prefLabel "SemEval-2010 Task 8"@en ;
                            skos:related provcred:tacred ;
                            skos:scopeNote "Used for relation extraction (provcred:RelationExtraction). Standard metric: macro-F1 (excluding Other)."@en ;
                            skos:topConceptOf provcred:DatasetScheme .


